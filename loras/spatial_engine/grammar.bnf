# Root: Handles empty arrays, loose lists, or coordinate blocks
root ::= (block_sequence | empty_scene)? ws?

empty_scene ::= "[" "]"

block_sequence ::= block ([ \t\r\n]* block)*

# A block can be a raw tag name or a fully positioned layout primitive
block ::= primitive (anchor? vector)?

primitive ::= "[" [a-zA-Z0-9_-]+ "]"

anchor ::= "[abs]" | "[@" [0-9]+ ("," ws? "@" [0-9]+)* "]"

# Vector strings support flat numbers, expressions, nested matrices, or config parameters
vector ::= "[" value ("," ws? value)* "]"

value ::= nested_array | parameter_assignment | expression | attribute | boolean_flag | num

# Captures matrices like [1,1,1.5] or [-0.6,0.6,-0.4] cleanly
nested_array ::= "[" (expression | num) ("," ws? (expression | num))* "]"

# Captures both taper=(z,0.5) and functional variations like taper(z,0.7) or noise(0.4)
parameter_assignment ::= [a-zA-Z_-]+ "=(" [a-zA-Z0-9_%-]+ "," ws? num ")" | [a-zA-Z_-]+ "(" [a-zA-Z0-9_%-]+ "," ws? num ")" | [a-zA-Z_-]+ "(" num ")"

# Expressions handle explicit signs directly adjacent to implicit multi-variables
expression ::= sign? term (op term)*

# Fully parses 'fw * 4', implicit coefficients like '-4fw', '-4fd', or solo variables
term ::= variable ("*" (variable | num))? | num variable? | "sym(" ws? expression ws? ")"
variable ::= "fw" | "hw" | "fd" | "hd" | "fh" | "hh" | "bd" | "bh" | "@idx"

# Layout modifier keywords or attributes
attribute ::= "noise=" num | "mesh"

# Single word boolean strings, percentage caps or surface state mappings like surf or -%
boolean_flag ::= "surf" | "-%" | [a-zA-Z_-]+

num ::= sign? [0-9]+ ("." [0-9]+)?

op ::= "+" | "-" | "*" | "/"

sign ::= ("+" | "-")+

ws ::= [ \t]+
ws_or_nl ::= [ \t\r\n]+